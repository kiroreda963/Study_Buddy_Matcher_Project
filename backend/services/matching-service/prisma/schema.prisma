generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MatchProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  preferredPace      String?
  preferredMode      String?
  preferredGroupSize Int?
  preferredStyle     String?
  courses            Course[]
  topics             Topic[]
  availabilitySlots  AvailabilitySlot[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Course {
  id             String       @id @default(uuid())
  name           String
  matchProfileId String
  matchProfile   MatchProfile @relation(fields: [matchProfileId], references: [id], onDelete: Cascade)
}

model Topic {
  id             String       @id @default(uuid())
  name           String
  matchProfileId String
  matchProfile   MatchProfile @relation(fields: [matchProfileId], references: [id], onDelete: Cascade)
}

model AvailabilitySlot {
  id             String       @id @default(uuid())
  userId         String
  dayOfWeek      String
  startTime      String
  endTime        String
  matchProfileId String
  matchProfile   MatchProfile @relation(fields: [matchProfileId], references: [id], onDelete: Cascade)
}

model Match {
  id            String   @id @default(uuid())
  userId        String
  matchedUserId String
  score         Float
  reasons       String[]
  ignored       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, matchedUserId])
}

model BuddyRequest {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, CANCELLED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Connection {
  id          String   @id @default(uuid())
  userId1     String
  userId2     String
  connectedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId1, userId2])
}