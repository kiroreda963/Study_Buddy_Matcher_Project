generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model StudySession {
  id           String       @id @default(uuid())
  authorId     String       
  topic        String
  date         DateTime
  duration     Int
  sessionType  SessionType
  contactInfo  String[]
  participants String[]
  invitations  Invitation[]
}

model Invitation {
  id        String           @id @default(uuid())
  authorId  String
  inviteeId String
  sessionId String
  status    InvitationStatus @default(PENDING)
  session   StudySession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([inviteeId, sessionId])
}

enum SessionType {
  ONLINE
  IN_PERSON
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}
